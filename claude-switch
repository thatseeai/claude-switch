#!/usr/bin/env python3
import os
import sys
import tty
import termios
import json
import subprocess
import urllib.request
import urllib.error
from datetime import datetime


TOKEN_FILE = os.path.expanduser("~/.claude/long-lived-auth-tokens.txt")
API_URL = "https://api.anthropic.com/v1/messages"


# ─── Usage ───────────────────────────────────────────────────────────
def fetch_usage(token):
    body = json.dumps({
        "model": "claude-haiku-4-5-20251001",
        "max_tokens": 1,
        "messages": [{"role": "user", "content": "hi"}],
    }).encode()

    req = urllib.request.Request(API_URL, data=body, method="POST", headers={
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json",
        "anthropic-version": "2023-06-01",
        "anthropic-beta": "oauth-2025-04-20",
    })

    try:
        resp = urllib.request.urlopen(req)
        headers = resp.headers
    except urllib.error.HTTPError as e:
        if e.code == 401:
            return None
        headers = e.headers

    prefix = "anthropic-ratelimit-"
    rl_headers = {k: v for k, v in headers.items() if k.lower().startswith(prefix)}

    def get(name):
        return rl_headers.get(f"anthropic-ratelimit-{name}", "")

    return {
        "session_utilization": float(get("unified-5h-utilization") or "0"),
        "session_reset": get("unified-5h-reset") or None,
        "session_status": get("unified-5h-status") or "unknown",
        "weekly_utilization": float(get("unified-7d-utilization") or "0"),
        "weekly_reset": get("unified-7d-reset") or None,
        "weekly_status": get("unified-7d-status") or "unknown",
        "overall_status": get("unified-status") or "unknown",
        "overage_status": get("unified-overage-status") or None,
    }


def progress_bar(ratio, width=20):
    filled = round(min(ratio, 1) * width)
    empty = width - filled
    pct = f"{ratio * 100:.1f}"

    if ratio >= 0.8:
        color = "\033[31m"  # red
    elif ratio >= 0.5:
        color = "\033[33m"  # yellow
    else:
        color = "\033[32m"  # green

    reset = "\033[0m"
    bar = color + "█" * filled + reset + "░" * empty
    return f"{bar}  {pct}%"


def format_reset(reset_value, show_day=False):
    if not reset_value:
        return "unknown"
    try:
        epoch = int(reset_value)
        if epoch == 0:
            return "unknown"
        dt = datetime.fromtimestamp(epoch)
        now = datetime.now()
        diff = dt - now

        if diff.total_seconds() < 0:
            return "just reset"

        diff_min = int(diff.total_seconds() // 60)
        diff_hr = diff_min // 60
        remain_min = diff_min % 60

        time_str = dt.strftime("%-I:%M %p")
        day_prefix = f"({dt.strftime('%a')}) " if show_day else ""

        if diff_hr > 0:
            return f"{day_prefix}{time_str} ({diff_hr}h {remain_min}m)"
        return f"{day_prefix}{time_str} ({diff_min}m)"
    except (ValueError, OSError):
        return "unknown"


def display_usage(name, data):
    bold = "\033[1m"
    dim = "\033[2m"
    reset = "\033[0m"

    if data is None:
        print(f"  {bold}{name}{reset}: \033[31mtoken expired\033[0m")
        return

    status = data["overall_status"]
    if status == "rate_limited":
        status_color = "\033[31m"
    elif status == "warning":
        status_color = "\033[33m"
    else:
        status_color = "\033[32m"

    print(f"  {bold}{name}{reset}")
    print(f"    Session (5h):  {progress_bar(data['session_utilization'])}")
    print(f"    Resets: {dim}{format_reset(data['session_reset'])}{reset}")
    print(f"    Weekly  (7d):  {progress_bar(data['weekly_utilization'])}")
    print(f"    Resets: {dim}{format_reset(data['weekly_reset'], show_day=True)}{reset}")

    overage = f"  |  Overage: {data['overage_status']}" if data["overage_status"] else ""
    print(f"    Status: {status_color}{status}{reset}{overage}")
    print()


# ─── Token file ──────────────────────────────────────────────────────
def load_tokens():
    if not os.path.isfile(TOKEN_FILE):
        print(f"토큰 파일이 없습니다: {TOKEN_FILE}")
        print()
        print("다음 형식으로 파일을 생성해주세요:")
        print()
        print("  <이름> <토큰>")
        print()
        print("예시:")
        print("  user1 AAXXYYZZ9387")
        print("  user2 BBZZABCD1234")
        sys.exit(1)

    names = []
    tokens = []
    with open(TOKEN_FILE) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split(None, 1)
            if len(parts) == 2:
                names.append(parts[0])
                tokens.append(parts[1])

    if not names:
        print(f"토큰 파일에 항목이 없습니다: {TOKEN_FILE}")
        sys.exit(1)

    return names, tokens


# ─── Account selection ───────────────────────────────────────────────
def select_account(names):
    selected = 0
    count = len(names)

    def draw_menu():
        for i, name in enumerate(names):
            if i == selected:
                print(f"\r\033[1;32m> {name}\033[0m")
            else:
                print(f"\r  {name}")

    def clear_menu():
        for _ in range(count):
            sys.stdout.write("\033[A\033[2K")
        sys.stdout.flush()

    def read_key():
        ch = sys.stdin.read(1)
        if ch == "\x1b":
            rest = sys.stdin.read(2)
            return ch + rest
        return ch

    print("계정을 선택하세요 (↑↓: 이동, Enter: 선택, q: 취소):")
    print()
    draw_menu()

    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        while True:
            key = read_key()
            if key == "\x1b[A":  # 위
                if selected > 0:
                    selected -= 1
            elif key == "\x1b[B":  # 아래
                if selected < count - 1:
                    selected += 1
            elif key in ("\r", "\n"):  # Enter
                break
            elif key in ("q", "Q", "\x03"):  # q, Q, Ctrl+C
                termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
                print("\r\n취소되었습니다.")
                sys.exit(0)
            else:
                continue
            clear_menu()
            draw_menu()
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)

    return selected


# ─── VSCode settings ─────────────────────────────────────────────────
def set_or_update_env_var(env_vars, name, value):
    """env_vars 리스트에서 이름이 name인 항목을 찾아 value로 업데이트하거나, 없으면 추가."""
    for e in env_vars:
        if e.get("name") == name:
            e["value"] = value
            return
    env_vars.append({"name": name, "value": value})


def update_vscode_settings(token, token_name, local_proxy_port=None):
    settings_path = os.path.join(os.getcwd(), ".vscode", "settings.json")

    # 기존 settings.json 읽기 또는 새로 생성
    if os.path.isfile(settings_path):
        with open(settings_path) as f:
            settings = json.load(f)
    else:
        os.makedirs(os.path.dirname(settings_path), exist_ok=True)
        settings = {}

    env_vars = settings.get("claudeCode.environmentVariables", [])

    # ANTHROPIC_API_KEY: 없으면 추가 (항상 value는 "")
    if not any(e.get("name") == "ANTHROPIC_API_KEY" for e in env_vars):
        env_vars.append({"name": "ANTHROPIC_API_KEY", "value": ""})

    # CLAUDE_CODE_OAUTH_NAME: 없으면 추가, 있으면 value 변경
    set_or_update_env_var(env_vars, "CLAUDE_CODE_OAUTH_NAME", token_name)

    # CLAUDE_CODE_OAUTH_TOKEN: 없으면 추가, 있으면 value 변경
    set_or_update_env_var(env_vars, "CLAUDE_CODE_OAUTH_TOKEN", token)

    # ANTHROPIC_BASE_URL: local_proxy_port가 지정된 경우에만 설정
    if local_proxy_port is not None:
        set_or_update_env_var(env_vars, "ANTHROPIC_BASE_URL", f"http://localhost:{local_proxy_port}")

    settings["claudeCode.environmentVariables"] = env_vars

    with open(settings_path, "w") as f:
        json.dump(settings, f, indent=2, ensure_ascii=False)
        f.write("\n")

    print(".vscode/settings.json 업데이트 완료")


def clear_vscode_settings():
    settings_path = os.path.join(os.getcwd(), ".vscode", "settings.json")

    if not os.path.isfile(settings_path):
        print(".vscode/settings.json 파일이 없습니다.")
        return

    with open(settings_path) as f:
        settings = json.load(f)

    env_vars = settings.get("claudeCode.environmentVariables", [])
    if not env_vars:
        print("claudeCode.environmentVariables 항목이 없습니다.")
        return

    remove_names = {"ANTHROPIC_API_KEY", "CLAUDE_CODE_OAUTH_TOKEN", "CLAUDE_CODE_OAUTH_NAME", "ANTHROPIC_BASE_URL"}
    env_vars = [e for e in env_vars if e.get("name") not in remove_names]

    if env_vars:
        settings["claudeCode.environmentVariables"] = env_vars
    else:
        del settings["claudeCode.environmentVariables"]

    with open(settings_path, "w") as f:
        json.dump(settings, f, indent=2, ensure_ascii=False)
        f.write("\n")

    print(".vscode/settings.json에서 토큰 정보를 제거했습니다.")


def check_vscode_gitignore():
    # git 저장소인지 확인
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--is-inside-work-tree"],
            capture_output=True, text=True,
        )
        if result.returncode != 0:
            return
    except FileNotFoundError:
        return

    # .vscode/settings.json이 gitignore로 무시되는지 확인
    result = subprocess.run(
        ["git", "check-ignore", "-q", ".vscode/settings.json"],
        capture_output=True,
    )
    if result.returncode != 0:
        print()
        print("\033[33m⚠ 경고: .vscode/settings.json이 .gitignore에 포함되어 있지 않습니다.\033[0m")
        print("  토큰이 git에 커밋될 수 있습니다. .gitignore에 추가를 권장합니다:")
        print("  echo '.vscode/settings.json' >> .gitignore")


# ─── Main ────────────────────────────────────────────────────────────
def print_help():
    print("사용법: claude-switch [옵션] [-- claude 인자...]")
    print()
    print("옵션:")
    print("  --help, -h          이 도움말을 출력합니다")
    print("  --list              등록된 계정 이름을 나열합니다")
    print("  --get-token NAME    해당 계정의 토큰을 출력합니다")
    print("  --usages            모든 계정의 사용량을 표시합니다")
    print("  --vscode            선택한 계정의 토큰을 .vscode/settings.json에 설정합니다")
    print("  --vscode-clear      .vscode/settings.json에서 토큰 정보를 제거합니다")
    print("  --local-proxy PORT  ANTHROPIC_BASE_URL=http://localhost:PORT 를 설정합니다")
    print()
    print(f"토큰 파일: {TOKEN_FILE}")


def main():
    # --help, -h: 도움말 출력 후 종료
    if "--help" in sys.argv or "-h" in sys.argv:
        print_help()
        return

    # --local-proxy PORT: ANTHROPIC_BASE_URL 설정용 포트 파싱
    local_proxy_port = None
    if "--local-proxy" in sys.argv:
        idx = sys.argv.index("--local-proxy")
        if idx + 1 >= len(sys.argv) or sys.argv[idx + 1].startswith("-"):
            print("오류: --local-proxy 옵션에 PORT를 지정해야 합니다.", file=sys.stderr)
            print("사용법: claude-switch --local-proxy <PORT>", file=sys.stderr)
            sys.exit(1)
        port_str = sys.argv[idx + 1]
        if not port_str.isdigit():
            print(f"오류: 포트 번호가 올바르지 않습니다: {port_str}", file=sys.stderr)
            sys.exit(1)
        local_proxy_port = int(port_str)

    names, tokens = load_tokens()

    # --list: 계정 이름 목록 출력 후 종료
    if "--list" in sys.argv:
        for name in names:
            print(name)
        return

    # --get-token NAME: 해당 이름의 토큰 출력 후 종료
    if "--get-token" in sys.argv:
        idx = sys.argv.index("--get-token")
        if idx + 1 >= len(sys.argv):
            print("사용법: claude-switch --get-token <이름>", file=sys.stderr)
            sys.exit(1)
        target = sys.argv[idx + 1]
        if target not in names:
            print(f"'{target}' 계정을 찾을 수 없습니다.", file=sys.stderr)
            print(f"사용 가능한 계정: {', '.join(names)}", file=sys.stderr)
            sys.exit(1)
        print(tokens[names.index(target)])
        return

    # --usages: 모든 토큰의 usage 표시 후 종료
    if "--usages" in sys.argv:
        print("\n\033[1mClaude API Rate Limits\033[0m")
        print("━" * 41)
        print()
        for name, token in zip(names, tokens):
            data = fetch_usage(token)
            display_usage(name, data)
        return

    # --vscode: 계정 선택 후 .vscode/settings.json 업데이트
    if "--vscode" in sys.argv:
        selected = select_account(names)
        print()
        print(f"선택: {names[selected]}")
        print()

        # 선택한 토큰의 usage 표시
        print("\033[1mClaude API Rate Limits\033[0m")
        print("━" * 41)
        print()
        data = fetch_usage(tokens[selected])
        display_usage(names[selected], data)

        update_vscode_settings(tokens[selected], names[selected], local_proxy_port)
        check_vscode_gitignore()
        return

    # --vscode-clear: .vscode/settings.json에서 토큰 제거
    if "--vscode-clear" in sys.argv:
        clear_vscode_settings()
        return

    # 일반 모드: 계정 선택
    sys.stdout.write("\033c")
    sys.stdout.flush()
    selected = select_account(names)

    print()
    print(f"선택: {names[selected]}")
    print()

    # 선택한 토큰의 usage 표시
    print("\033[1mClaude API Rate Limits\033[0m")
    print("━" * 41)
    print()
    data = fetch_usage(tokens[selected])
    display_usage(names[selected], data)

    # claude 실행
    skip_args = {"--usages", "--local-proxy"}
    proxy_idx = sys.argv.index("--local-proxy") if "--local-proxy" in sys.argv else -1
    skip_idx = {proxy_idx + 1} if proxy_idx >= 0 else set()
    claude_args = [a for i, a in enumerate(sys.argv[1:], 1) if a not in skip_args and i not in skip_idx]
    if local_proxy_port is not None:
        os.environ["ANTHROPIC_BASE_URL"] = f"http://localhost:{local_proxy_port}"
    os.environ["CLAUDE_CODE_OAUTH_TOKEN"] = tokens[selected]
    os.environ["CLAUDE_CODE_OAUTH_NAME"] = names[selected]
    os.execvp("claude", ["claude"] + claude_args)


if __name__ == "__main__":
    main()
